  "keyFeatures": [
    "HD video and audio calls with WebRTC",
    "Real-time screen sharing",
    "In-meeting chat with Socket.io",
    "Host controls and room management",
    "Guest access without registration",
    "Responsive design for mobile and desktop"
  ],
  "publicApiSurface": [
    "POST /auth/register - Register new user",
    "POST /auth/login - Authenticate user",
    "POST /rooms - Create new meeting room",
    "GET /rooms/:code - Get room details",
    "PATCH /rooms/:id - Update room settings",
    "POST /rooms/:code/join - Join meeting room",
    "GET /users/profile - Get user profile",
    "PATCH /users/profile - Update user profile",
    "WS /signaling - WebRTC signaling events (offer, answer, ice-candidate)",
    "WS /chat - Real-time chat events (message, join, leave)"
  ]
